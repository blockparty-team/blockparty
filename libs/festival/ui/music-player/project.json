{
  "name": "music-player",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/festival/ui/music-player/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "libs/festival/ui/music-player/ng-package.json",
        "tsConfig": "libs/festival/ui/music-player/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/festival/ui/music-player/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "tsConfig": "libs/festival/ui/music-player/tsconfig.spec.json",
        "runnerConfig": true
      },
      "configurations": {
        "ci": {
          "watch": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
