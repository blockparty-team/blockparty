{
  "name": "studieby",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/studieby/src",
  "projectType": "application",
  "prefix": "app",
  "generators": {},
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "options": {
        "outputPath": "dist/apps/studieby",
        "index": "apps/studieby/src/index.html",
        "polyfills": [
          "apps/studieby/src/polyfills.ts"
        ],
        "tsConfig": "apps/studieby/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/studieby/src/assets",
            "output": "assets"
          },
          "apps/studieby/src/manifest.webmanifest",
          "apps/studieby/src/OneSignalSDKWorker.js"
        ],
        "styles": [
          "apps/studieby/src/global.scss",
          "apps/studieby/src/theme/variables.scss"
        ],
        "scripts": [],
        "extractLicenses": false,
        "sourceMap": true,
        "optimization": false,
        "namedChunks": true,
        "serviceWorker": "apps/studieby/ngsw-config.json",
        "allowedCommonJsDependencies": [
          "maplibre-gl",
          "onesignal-cordova-plugin",
          "ws"
        ],
        "browser": "apps/studieby/src/main.ts"
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "libs/shared/enviroments/src/lib/environment.ts",
              "with": "libs/shared/enviroments/src/lib/studieby.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "10mb",
              "maximumError": "15mb"
            }
          ]
        },
        "development": {
          "fileReplacements": [
            {
              "replace": "libs/shared/enviroments/src/lib/environment.ts",
              "with": "libs/shared/enviroments/src/lib/studieby.dev.ts"
            }
          ],
          "optimization": false,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "aot": true,
          "extractLicenses": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "10mb",
              "maximumError": "15mb"
            }
          ]
        },
        "ci": {
          "progress": false
        }
      }
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "options": {
        "buildTarget": "studieby:build"
      },
      "configurations": {
        "production": {
          "buildTarget": "studieby:build:production"
        },
        "development": {
          "buildTarget": "studieby:build:development"
        },
        "ci": {
          "progress": false
        }
      },
      "continuous": true
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "studieby:build"
      }
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "tsConfig": "apps/studieby/tsconfig.spec.json",
        "runnerConfig": true
      },
      "configurations": {
        "ci": {
          "watch": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "{projectRoot}/**/*.ts",
          "{projectRoot}/**/*.html"
        ]
      }
    },
    "build-sync-prod": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/studieby/",
        "commands": [
          "nx run studieby:build:production",
          "npx cap sync"
        ],
        "parallel": false
      }
    },
    "build-sync-dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/studieby/",
        "commands": [
          "npx nx run studieby:build",
          "npx cap sync"
        ],
        "parallel": false
      }
    },
    "open-xcode": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/studieby/",
        "command": "npx cap open ios"
      }
    },
    "open-android-studio": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/studieby/",
        "command": "npx cap open android"
      }
    }
  }
}
